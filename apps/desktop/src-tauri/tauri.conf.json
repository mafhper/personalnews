{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PersonalNews Desktop",
  "version": "1.4.5",
  "identifier": "io.mafhper.personalnews",
  "build": {
    "beforeDevCommand": "bun run --cwd ../.. dev:local",
    "beforeBuildCommand": "bun run --cwd ../.. build:app:desktop && bun run --cwd ../.. prepare:backend",
    "devUrl": "http://127.0.0.1:5173/#feed",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PersonalNews",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "maximized": false,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/personalnews-backend-x86_64-apple-darwin",
      "binaries/personalnews-backend-aarch64-apple-darwin",
      "binaries/personalnews-backend-x86_64-unknown-linux-gnu",
      "binaries/personalnews-backend-x86_64-pc-windows-msvc"
    ],
    "macos": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "dmg": {
      "background": null,
      "windowPosition": {
        "x": 400,
        "y": 400
      },
      "windowSize": {
        "width": 540,
        "height": 380
      },
      "appPosition": {
        "x": 410,
        "y": 150
      },
      "iconPosition": {
        "x": 130,
        "y": 150
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "PersonalNews",
        "installerHooks": "windows/hooks.nsh"
      },
      "wix": {
        "language": [
          "pt-BR",
          "en-US"
        ]
      }
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": false
  }
}
