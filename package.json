{
  "name": "personal-news",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "description": "A fast, modern personal news aggregator that serves as your browser homepage. Built with React, TypeScript, and optimized with Bun.",
  "author": "mafhper",
  "license": "MIT",
  "keywords": [
    "rss",
    "news",
    "aggregator",
    "homepage",
    "react",
    "typescript",
    "bun",
    "vite"
  ],
  "scripts": {
    "dev": "bun vite",
    "backend:start": "bun run apps/backend/src/server.ts",
    "dev:local": "node scripts/run-local-stack.mjs dev",
    "prepare:backend": "node scripts/prepare-backend.mjs",
    "build:app:desktop": "node scripts/build-desktop-app.mjs",
    "build:app": "npm run promo:changelog && bun run config:sync && bunx tsc --noEmit && bun vite build",
    "build:dashboard": "node quality-core/scripts/build-dashboard.cjs",
    "build": "bun run build:app && bun run build:dashboard",
    "preview": "bun vite preview",
    "test:drift": "node quality-core/scripts/check-test-classification.cjs",
    "test": "bun run test:drift && bun vitest run --environment jsdom --config quality-core/config/vitest.config.core.ts",
    "test:core": "bun run test",
    "test:core:serial": "bun run test:drift && node quality-core/scripts/run-vitest-serial.cjs --config=quality-core/config/vitest.config.core.ts --test-timeout=15000",
    "test:smoke": "bun run test:drift && bun vitest run --environment jsdom --config quality-core/config/vitest.config.smoke.ts",
    "test:smoke:serial": "bun run test:drift && node quality-core/scripts/run-vitest-serial.cjs --config=quality-core/config/vitest.config.smoke.ts --test-timeout=10000",
    "test:all": "bun run test:drift && bun vitest run --environment jsdom --config quality-core/config/vitest.config.all.ts",
    "test:all:serial": "bun run test:drift && node quality-core/scripts/run-vitest-serial.cjs --config=quality-core/config/vitest.config.all.ts --test-timeout=15000",
    "test:fast": "bun run test:smoke",
    "test:watch": "bun run test:drift && bun vitest --environment jsdom --config quality-core/config/vitest.config.core.ts",
    "test:coverage": "node quality-core/cli/run-coverage.cjs",
    "test:coverage:quick": "node quality-core/cli/run-coverage.cjs --quick",
    "test:coverage:quiet": "node quality-core/cli/run-coverage.cjs --quiet",
    "test:coverage:quick-quiet": "node quality-core/cli/run-coverage.cjs --quick --quiet",
    "test:coverage:silent": "node quality-core/cli/run-coverage.cjs --silent",
    "test:coverage:quick-silent": "node quality-core/cli/run-coverage.cjs --quick --silent",
    "test:e2e": "node quality-core/scripts/run-playwright.cjs test -c playwright.config.cjs",
    "test:e2e:ui": "node quality-core/scripts/run-playwright.cjs test --ui -c playwright.config.cjs",
    "test:e2e:headed": "node quality-core/scripts/run-playwright.cjs test --headed -c playwright.config.cjs",
    "test:e2e:install": "node quality-core/scripts/run-playwright.cjs install",
    "test:feeds": "bun run quality-core/scripts/testFeeds.ts",
    "type-check": "tsc --noEmit -p tsconfig.json --incremental --tsBuildInfoFile performance-reports/tsbuildinfo",
    "clean": "bunx rimraf dist node_modules/.vite",
    "ci:preflight": "node scripts/run-github-preflight.mjs --all",
    "ci:preflight:pages": "node scripts/run-github-preflight.mjs --pages",
    "ci:preflight:desktop": "node scripts/run-github-preflight.mjs --desktop",
    "deploy": "bun run build && git add dist/ && git commit -m \"Deploy: Update build\" && git push origin main",
    "promo": "bun vite build && node scripts/serve-promo.cjs",
    "promo:changelog": "node quality-core/scripts/generate-changelog.cjs",
    "quality:ui": "bun quality-core/scripts/run-ui-gate.ts",
    "config:sync": "bun quality-core/scripts/sync-config.ts",
    "i18n:audit": "node quality-core/scripts/i18n-audit.cjs",
    "i18n:sync": "node quality-core/scripts/i18n-sync.cjs",
    "perf:lighthouse": "node quality-core/scripts/performance-gate/run-lighthouse.cjs",
    "perf:lighthouse:home": "node quality-core/scripts/performance-gate/run-lighthouse.cjs --home",
    "perf:lighthouse:feed": "node quality-core/scripts/performance-gate/run-lighthouse.cjs --feed",
    "perf:analyze": "node quality-core/scripts/performance-gate/analyze.cjs",
    "dashboard": "bun run quality-core/dashboard-server.ts",
    "lint": "bunx eslint . --ext .ts,.tsx --cache --cache-location performance-reports/.eslintcache",
    "lint:fast": "node quality-core/scripts/lint-changed.cjs",
    "lint:components": "bunx eslint components --ext .ts,.tsx --cache --cache-location performance-reports/.eslintcache",
    "lint:services": "bunx eslint services hooks utils config --ext .ts,.tsx --cache --cache-location performance-reports/.eslintcache",
    "lint:quality-core": "bunx eslint quality-core --ext .ts,.tsx --cache --cache-location performance-reports/.eslintcache",
    "security:scan": "node quality-core/scripts/security-scan.cjs --repo-wide",
    "security:scan:app": "node quality-core/scripts/security-scan.cjs",
    "audit:full": "node quality-core/scripts/full-quality-audit.cjs",
    "audit:capture": "bun run quality-core/capture-audit.ts",
    "cleanup": "node quality-core/scripts/run-pwsh.cjs quality-core/scripts/cleanup-servers.ps1",
    "system:start": "node quality-core/scripts/run-pwsh.cjs quality-core/scripts/start-all.ps1",
    "scripts:audit:all": "node quality-core/scripts/audit-package-scripts.cjs",
    "scripts:audit:all:fail": "node quality-core/scripts/audit-package-scripts.cjs --fail-on-error",
    "scripts:audit:area": "node quality-core/scripts/audit-package-scripts.cjs --areas=build-config,quality-static,tests,quality-core,performance-analysis,composite-pipelines",
    "quality:core": "node quality-core/cli/quality.cjs",
    "quality:core:quick": "node quality-core/cli/quality.cjs --quick",
    "quality:core:silent": "node quality-core/cli/quality.cjs --silent",
    "quality:core:quick-silent": "node quality-core/cli/quality.cjs --quick --silent",
    "quality:coverage": "node quality-core/cli/run-coverage.cjs",
    "quality:coverage:quick": "node quality-core/cli/run-coverage.cjs --quick",
    "quality:coverage:quiet": "node quality-core/cli/run-coverage.cjs --quiet",
    "quality:coverage:quick-quiet": "node quality-core/cli/run-coverage.cjs --quick --quiet",
    "quality:coverage:silent": "node quality-core/cli/run-coverage.cjs --silent",
    "quality:coverage:quick-silent": "node quality-core/cli/run-coverage.cjs --quick --silent",
    "quality:lighthouse": "node quality-core/cli/run-lighthouse.cjs",
    "quality:lighthouse:home": "node quality-core/cli/run-lighthouse.cjs --home",
    "quality:lighthouse:feed": "node quality-core/cli/run-lighthouse.cjs --feed",
    "quality:lighthouse:silent": "node quality-core/cli/run-lighthouse.cjs --silent",
    "quality:snapshot": "bun quality-core/generate-snapshot.ts",
    "quality:dashboard": "bun quality-core/dashboard-server.ts",
    "quality:gate": "node quality-core/cli/run.cjs",
    "quality:gate:quick": "node quality-core/cli/run.cjs --quick",
    "quality:gate:silent": "node quality-core/cli/run.cjs --silent",
    "quality:gate:quick-silent": "node quality-core/cli/run.cjs --quick --silent",
    "quality:gate:local-silent:nolint": "node quality-core/cli/run.cjs --local --silent --no-lint",
    "quality:gate:local-silent": "node quality-core/cli/run.cjs --local --silent",
    "analysis": "node quality-core/cli/run-analysis.cjs",
    "analysis:bundle": "node quality-core/cli/run-analysis.cjs",
    "analysis:silent": "node quality-core/cli/run-analysis.cjs --silent",
    "quality:dashboard:refresh": "bun quality-core/scripts/refresh-dashboard-cache.ts",
    "quality:check": "run-p lint type-check test security:scan",
    "quality:full": "rimraf dist && run-p lint type-check test:core quality:core",
    "quality:full:silent": "rimraf dist && run-p lint type-check test:core \"quality:core:silent\"",
    "quality:full:quick": "rimraf dist && run-p lint type-check test:core \"quality:core:quick\"",
    "quality:full:quick-silent": "rimraf dist && run-p lint type-check test:core \"quality:core:quick-silent\"",
    "quality:reports:all": "node -e \"console.log('[quality:reports:all] build:app')\" && bun run build:app && node -e \"console.log('[quality:reports:all] quality:core --fail-on-error')\" && node quality-core/cli/quality.cjs --fail-on-error && node -e \"console.log('[quality:reports:all] quality:lighthouse')\" && bun run quality:lighthouse && node -e \"console.log('[quality:reports:all] analysis')\" && bun run analysis && node -e \"console.log('[quality:reports:all] quality:snapshot')\" && bun run quality:snapshot",
    "quality:reports:all:silent": "node -e \"console.log('[quality:reports:all:silent] build:app')\" && bun run build:app && node -e \"console.log('[quality:reports:all:silent] quality:core:silent --fail-on-error')\" && node quality-core/cli/quality.cjs --silent --fail-on-error && node -e \"console.log('[quality:reports:all:silent] quality:lighthouse:silent')\" && bun run quality:lighthouse:silent && node -e \"console.log('[quality:reports:all:silent] analysis:silent')\" && bun run analysis:silent && node -e \"console.log('[quality:reports:all:silent] quality:snapshot')\" && bun run quality:snapshot",
    "quality:ci": "node -e \"console.log('[quality:ci] quality:full:silent')\" && bun run quality:full:silent && node -e \"console.log('[quality:ci] quality:reports:all:silent')\" && bun run quality:reports:all:silent",
    "quality:ci:quick-silent": "node -e \"console.log('[quality:ci:quick-silent] build')\" && bun run build && node -e \"console.log('[quality:ci:quick-silent] quality:gate --quick --silent')\" && node quality-core/cli/run.cjs --quick --silent && node -e \"console.log('[quality:ci:quick-silent] quality:core --quick --silent --fail-on-error')\" && node quality-core/cli/quality.cjs --quick --silent --fail-on-error && node -e \"console.log('[quality:ci:quick-silent] quality:lighthouse:silent')\" && node quality-core/cli/run-lighthouse.cjs --silent && node -e \"console.log('[quality:ci:quick-silent] analysis:silent')\" && node quality-core/cli/run-analysis.cjs --silent",
    "tauri": "tauri",
    "desktop:build": "cd apps/desktop && bunx tauri build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/jsdom": "^28.0.1",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "autoprefixer": "^10.4.27",
    "bun-types": "^1.3.12",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "lighthouse": "^13.0.3",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.5",
    "vitest": "4.1.2"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mozilla/readability": "^0.6.0",
    "@mui/material": "^7.3.9",
    "@types/dompurify": "^3.2.0",
    "@xmldom/xmldom": "^0.9.9",
    "baseline-browser-mapping": "^2.10.17",
    "caniuse-lite": "^1.0.30001780",
    "dompurify": "^3.4.0",
    "eslint-plugin-security": "^4.0.0",
    "i18next": "^25.10.10",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "npm-run-all2": "^8.0.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.6.6",
    "react-virtuoso": "^4.18.4",
    "rimraf": "^6.1.2",
    "zod": "^4.3.6"
  },
  "resolutions": {
    "yauzl": "3.2.1",
    "brace-expansion": "5.0.5",
    "picomatch": "4.0.4",
    "yaml": "1.10.3"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "picomatch": "4.0.4",
    "yaml": "1.10.3"
  }
}
